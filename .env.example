# Firebase Configuration
# Copy this file to .env.local and fill in your actual values
#
# Native (Capacitor): download `GoogleService-Info.plist` (iOS) and `google-services.json` (Android)
# from Firebase Console → Project settings → Your apps, and place them at:
#   ios/App/App/GoogleService-Info.plist
#   android/app/google-services.json

VITE_FIREBASE_API_KEY=your_api_key_here
# Default is project.firebaseapp.com. Use your custom domain on Auth authorized domains + Hosting.
# Client authDomain does NOT change the domain inside password-reset *emails*; set that under
# Firebase Console → Authentication → Templates → customize action URL (e.g. …/__/auth/action).
# VITE_FIREBASE_AUTH_DOMAIN=myprovisions.app
VITE_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
# Optional: where to send the user after completing a password reset (must be an authorized domain).
# Defaults to ${origin}/signin when unset.
# VITE_PASSWORD_RESET_CONTINUE_URL=https://myprovisions.app/signin
#
# For reliable reset on your own UI: Firebase Console → Authentication → Templates → Password reset
# → customize action URL to: https://myprovisions.app/signin (Firebase appends ?mode=…&oobCode=…).
VITE_FIREBASE_DATABASE_URL=https://your_project_id-default-rtdb.firebaseio.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
VITE_FIREBASE_APP_ID=your_app_id
# Optional: Google Analytics (GA4) — Firebase Console → Project settings → Your apps → Measurement ID
# VITE_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Firebase App Check (reCAPTCHA v3) — required in production (runtime throws if missing).
# Google reCAPTCHA admin → v3 keys; Firebase Console → App Check → register the web app with that site key.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_v3_site_key
# Local dev only: optional fixed debug token (register the same string under App Check → Debug tokens).
# If unset, npm run dev uses automatic debug token (printed once in the browser console).
# VITE_APPCHECK_DEBUG_TOKEN=
